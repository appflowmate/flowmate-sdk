{
  "name": "flowmate-sdk",
  "version": "0.1.0",
  "description": "SDK for building FlowMate-compatible server responses",
  "module": "src/index.ts",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node && bun run build:types",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir dist",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "flowmate",
    "ios",
    "shortcuts",
    "automation",
    "webhook"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
