{
  "name": "@flow-mate/sdk",
  "version": "0.1.0",
  "description": "SDK for building FlowMate-compatible server responses",
  "module": "src/index.ts",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "bunx --bun bun build src/index.ts --outdir dist --target node && bunx tsc -p tsconfig.build.json",
    "test": "bun test",
    "prepublishOnly": "bun run build"
  },
  "keywords": [
    "flowmate",
    "ios",
    "shortcuts",
    "automation",
    "webhook",
    "siri",
    "n8n"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/appflowmate/flowmate-sdk.git"
  },
  "homepage": "https://flow-mate.app",
  "bugs": {
    "url": "https://github.com/appflowmate/flowmate-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5"
  }
}
